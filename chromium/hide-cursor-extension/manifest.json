{
  "manifest_version": 3,
  "name": "Auto Hide Cursor",
  "version": "1.1",
  "description": "Hide the cursor immediately and after 1s of inactivity, show on input.",
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
